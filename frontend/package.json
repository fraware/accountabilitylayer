{
  "name": "accountability-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend for the Accountability Layer project.",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "codegen:api": "openapi-typescript ../docs/api-spec.yaml -o src/types/api.d.ts",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\" \"eslint.config.js\" \"vite.config.js\" \"cypress.config.js\" \"tests/**/*.{js,jsx}\" \"tsconfig.json\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\" \"eslint.config.js\" \"vite.config.js\" \"cypress.config.js\" \"tests/**/*.{js,jsx}\" \"tsconfig.json\"",
    "cypress:run": "cypress run",
    "cypress:open": "cypress open",
    "bench": "node bench/ui-benchmarks.js",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=bench/lighthouse-report.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.6",
    "@mui/material": "^6.4.6",
    "@mui/x-date-pickers": "^7.24.1",
    "@tanstack/react-query": "^5.64.2",
    "axios": "^1.7.9",
    "date-fns": "^3.6.0",
    "jwt-decode": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intersection-observer": "^9.14.0",
    "react-router-dom": "^7.6.1",
    "react-virtualized-auto-sizer": "^1.0.7",
    "react-window": "^1.8.10",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cypress": "^14.0.2",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "lighthouse": "^12.3.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.4.2",
    "puppeteer": "^24.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.4"
  }
}

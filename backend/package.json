{
  "name": "accountability-backend",
  "version": "1.0.0",
  "description": "Backend service for the Accountability Layer project.",
  "main": "dist/app.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "test": "mocha --config .mocharc.cjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,ts}\" \"tests/**/*.js\" \"eslint.config.js\"",
    "format:check": "prettier --check \"src/**/*.{js,ts}\" \"tests/**/*.js\" \"eslint.config.js\"",
    "bench": "node bench/run-benchmarks.js",
    "profile": "node --prof bench/profile.js",
    "bench:comprehensive": "node bench/comprehensive-benchmark.js",
    "bench:mongo": "node bench/mongo-index-analyzer.js",
    "bench:e2e": "node bench/end-to-end-profiler.js",
    "migrate": "node scripts/migrate-to-timeseries.js",
    "worker": "node dist/services/logWorker.js",
    "notifier": "node dist/services/notifierService.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/instrumentation": "^0.55.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "axios": "^1.7.9",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "nats": "^2.29.3",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.7.0",
    "swagger-ui-express": "^5.0.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^10.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/parser": "^8.21.0",
    "0x": "^5.0.0",
    "autocannon": "^7.15.0",
    "chai": "^4.5.0",
    "clinic": "^13.0.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "mocha": "^11.0.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "sinon": "^19.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
